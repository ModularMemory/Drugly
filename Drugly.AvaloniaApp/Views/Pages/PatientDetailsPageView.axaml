<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:doctor="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Drugly.AvaloniaApp.Views.Pages.PatientDetailsPageView"
             x:DataType="doctor:PatientDetailsPageViewModel"
             d:DataContext="{x:Static design:DesignData.PatientDetailsPageViewModel}">
    Welcome to Avalonia!
</UserControl>
