<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             xmlns:pages="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Drugly.AvaloniaApp.Views.Pages.DoctorMainView"
             x:DataType="pages:DoctorMainViewModel"
             d:DataContext="{x:Static design:DesignData.DoctorMainViewModel}">
    <Grid Margin="8"
          RowSpacing="10"
          RowDefinitions="Auto,*">

        <!-- Upper content -->
        <Grid Grid.Row="0">
            <StackPanel Spacing="2">
                <TextBlock Classes="H1"
                           Text="Hello, Doctor!" />
                <Separator />
            </StackPanel>
        </Grid>

        <!-- Lower content -->
        <Grid Grid.Row="1"
              ColumnSpacing="2">
            <TextBlock Classes="H1" Text="Lower!" />
        </Grid>
    </Grid>
</UserControl>