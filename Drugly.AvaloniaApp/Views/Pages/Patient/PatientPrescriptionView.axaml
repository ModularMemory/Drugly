<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:doctor="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:patient="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages.Patient"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Drugly.AvaloniaApp.Views.Pages.PatientPrescriptionView"
             x:DataType="patient:PatientPrescriptionDetailsViewModel"
             d:DataContext="{x:Static design:DesignData.PatientPrescriptionDetailsViewModel}">


    <Grid Margin="8"
          RowSpacing="16"
          RowDefinitions="Auto,*">

        <!-- Upper content -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              RowSpacing="{Binding $parent[Grid].RowSpacing}"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8">

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Classes="Flat"
                    Content="&lt;"
                    Command="{Binding NavigateBackCommand}" />

            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Classes="H1"
                       Text="Medication 1" />

            <Separator Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="2" />
        </Grid>

        <!-- Lower content -->
        <Grid Grid.Row="1"
              RowDefinitions="Auto,Auto,Auto"
              RowSpacing="16">

            <suki:Stepper Grid.Row="0"
                          AlternativeStyle="True"
                          Index="{Binding StepIndex}"
                          Steps="{Binding Steps}" />
            
            <Separator Grid.Row="1"
                       Grid.Column="0"/>
            
            <TabControl Grid.Row="2">
                <TabItem Header="Usage Instructions">
                    
                    <TextBlock Classes="H3"
                               Text="Take 2 35mg tablets twice a day." />
                    
                </TabItem>
                    
                <TabItem Header="Billing Information" 
                         IsEnabled="False">
                    
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="16">
                        
                        <!-- Card Number -->
                        <StackPanel Grid.Row="0"
                                    Spacing="2">
                            <TextBlock Text="Cardholder Name"
                                       Classes="H3" />
                            <TextBox Text="{Binding CardHolder}"
                                     Watermark="J Doe" />
                        </StackPanel>
                        
                        <!-- Card Number -->
                        <StackPanel Grid.Row="1"
                                    Spacing="2">
                            <TextBlock Text="Card Number"
                                       Classes="H3" />
                            <TextBox Text="{Binding CardNumber}"
                                     Watermark="XXXX-XXXX-XXXX-XXXX" />
                        </StackPanel>
                        
                        <!-- Expiry/CVV -->
                        <Grid Grid.Row="2" 
                              ColumnDefinitions="Auto,Auto"
                              ColumnSpacing="8">
                            
                            <StackPanel Grid.Column="0"
                                        Spacing="2">
                                <TextBlock Text="Expiry Date"
                                           Classes="H4" />
                                <TextBox Text="{Binding CardExpiry}"
                                         Watermark="MM/YY" />
                            </StackPanel>
                            
                            <StackPanel Grid.Column="1"
                                        Spacing="2">
                                <TextBlock Text="CVV"
                                           Classes="H4" />
                                <TextBox Text="{Binding CardCCV}"
                                         Watermark="000" />
                            </StackPanel>
                            
                        </Grid>
                        
                        <Button Grid.Row="3"
                                Classes="Flat"
                                Content="Submit"
                                Command="{Binding SubmitBillingInfoCommand}" />
                        
                    </Grid>
                    
                </TabItem>
                
            </TabControl>

        </Grid>
        
    </Grid>

</UserControl>