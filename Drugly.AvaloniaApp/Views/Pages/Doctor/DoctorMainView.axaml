<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             xmlns:doctor="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages.Doctor"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Drugly.AvaloniaApp.Views.Pages.Doctor.DoctorMainView"
             x:DataType="doctor:DoctorMainViewModel"
             d:DataContext="{x:Static design:DesignData.DoctorMainViewModel}">
    <Grid>
        <StackPanel Spacing="16">
            <Button Classes="Large Flat"
                    Command="{Binding ViewPatientsCommand}"
                    suki:ButtonExtensions.Icon="{icons:MaterialIconExt People}">
                <TextBlock Classes="H2"
                           Text="View Patients" />
            </Button>

            <Button Classes="Large Flat"
                    Command="{Binding PrescribeMedicationsCommand}"
                    suki:ButtonExtensions.Icon="{icons:MaterialIconExt Medication}">
                <TextBlock Classes="H2"
                           Text="Browse Medications" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>