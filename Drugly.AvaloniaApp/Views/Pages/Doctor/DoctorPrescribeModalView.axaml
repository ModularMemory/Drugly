<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             xmlns:doctor="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages.Doctor"
             xmlns:suki="https://github.com/kikipoulet/SukiUI"
             xmlns:controls="clr-namespace:Drugly.AvaloniaApp.Controls"
             xmlns:icons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             MinWidth="600" MaxWidth="1000" MinHeight="600"
             mc:Ignorable="d"
             x:Class="Drugly.AvaloniaApp.Views.Pages.Doctor.DoctorPrescribeModalView"
             x:DataType="doctor:DoctorPrescribeModalViewModel"
             d:DataContext="{x:Static design:DesignData.DoctorPrescribeModalViewModel}">
    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,*,Auto,Auto,Auto"
          RowSpacing="12">
        <!-- Heading -->
        <TextBlock Grid.Row="0"
                   Classes="H1"
                   Text="{Binding Medication.Name, StringFormat=Prescribing {0}, FallbackValue=Unknown Medication}" />

        <Separator Grid.Row="1" />

        <!-- First/last name -->
        <Grid Row="2"
              IsSharedSizeScope="True"
              ColumnDefinitions="*,*"
              ColumnSpacing="12">

            <!-- First name -->
            <StackPanel Grid.Column="0"
                        Spacing="2">
                <TextBlock Text="First Name"
                           Classes="H3" />
                <TextBox Text="{Binding PatientFirstName}"
                         Watermark="John" />
            </StackPanel>

            <!-- Last name -->
            <StackPanel Grid.Column="1"
                        Spacing="2">
                <TextBlock Text="Last Name"
                           Classes="H3" />
                <TextBox Text="{Binding PatientLastName}"
                         Watermark="Doe" />
            </StackPanel>
        </Grid>

        <!-- Email -->
        <StackPanel Grid.Row="3"
                    Spacing="2">
            <TextBlock Text="Email"
                       Classes="H3" />
            <TextBox Text="{Binding PatientEmail}"
                     Watermark="jdoe@example.com" />
        </StackPanel>

        <!-- Dosage -->
        <StackPanel Grid.Row="4"
                    Spacing="2">
            <TextBlock Text="Dosage"
                       Classes="H3" />

            <WrapPanel Orientation="Horizontal"
                       ItemSpacing="6"
                       LineSpacing="4">
                <TextBlock Text="Take"
                           VerticalAlignment="Center" />
                <TextBox Text="{Binding DosagePerDay}"
                         Watermark="0mg"
                         VerticalAlignment="Center" />
                <TextBlock Text="every"
                           VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding DaysBetweenDosage}"
                               Watermark="0"
                               Minimum="0"
                               FormatString="N0"
                               VerticalAlignment="Center" />
                <TextBlock Text="days for"
                           VerticalAlignment="Center" />
                <NumericUpDown Value="{Binding DaysPrescribed}"
                               Watermark="1"
                               Minimum="1"
                               FormatString="N0"
                               VerticalAlignment="Center" />
                <TextBlock Text="days."
                           VerticalAlignment="Center" />
            </WrapPanel>
        </StackPanel>

        <!-- Notes textbox -->
        <Grid Row="5"
              RowDefinitions="Auto,*"
              RowSpacing="2"
              IsSharedSizeScope="True">
            <TextBlock Grid.Row="0"
                       Text="Additional notes"
                       Classes="H3" />
            <TextBox Grid.Row="1"
                     Text="{Binding PrescriptionNotes}"
                     AcceptsReturn="True"
                     Watermark="Additional usage notes"
                     TextWrapping="Wrap"
                     MaxLength="500" />
        </Grid>

        <!-- Doctor signature -->
        <StackPanel Grid.Row="6"
                    Spacing="2">
            <TextBlock Text="Signature"
                       Classes="H3" />

            <suki:GlassCard Padding="10">
                <StackPanel Spacing="6">
                    <Panel>
                        <controls:DrawableBitmap
                            Name="SignatureBitmap"
                            Background="White"
                            Foreground="Black"
                            StrokeThickness="2"
                            Width="650"
                            Height="150" />

                        <Separator Margin="10,50,10,0"
                                   IsHitTestVisible="False"
                                   Foreground="Gray"/>
                    </Panel>

                    <!-- This sucks, but the alternative is figuring out how to make
                    SignatureBitmap._bitmap an image source, and I'm tired -->
                    <Button Classes="Discrete"
                            Content="Clear"
                            Command="{Binding #SignatureBitmap.ClearCommand}"
                            suki:ButtonExtensions.Icon="{icons:MaterialIconExt Close}" />
                </StackPanel>
            </suki:GlassCard>
        </StackPanel>

        <!-- Error text -->
        <TextBlock Grid.Row="7"
                   Classes="Body Danger"
                   TextAlignment="Center"
                   Text="{Binding ErrorText}" />

        <!-- Cancel/confirm buttons -->
        <StackPanel Grid.Row="8"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Spacing="16">
            <Button Content="Cancel"
                    Classes="Danger"
                    Command="{Binding CancelCommand}" />

            <Button Content="Create Prescription"
                    Classes="Flat"
                    Command="{Binding CreatePrescriptionCommand}"
                    CommandParameter="{Binding #SignatureBitmap}"
                    suki:ButtonExtensions.ShowProgress="{Binding IsLoading}" />
        </StackPanel>

    </Grid>
</UserControl>