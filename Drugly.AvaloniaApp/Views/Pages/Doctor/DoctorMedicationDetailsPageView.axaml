<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:design="clr-namespace:Drugly.AvaloniaApp.Design"
             xmlns:doctor="clr-namespace:Drugly.AvaloniaApp.ViewModels.Pages.Doctor"
             xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia"
             mc:Ignorable="d" d:DesignWidth="1400" d:DesignHeight="900"
             x:Class="Drugly.AvaloniaApp.Views.Pages.Doctor.DoctorMedicationDetailsPageView"
             x:DataType="doctor:DoctorMedicationDetailsPageViewModel"
             d:DataContext="{x:Static design:DesignData.DoctorMedicationDetailsPageViewModel}">
    <Grid Margin="8"
          RowSpacing="16"
          RowDefinitions="Auto,*">

        <!-- Upper content -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto"
              RowSpacing="{Binding $parent[Grid].RowSpacing}"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="8">

            <Button Grid.Row="0"
                    Grid.Column="0"
                    Classes="Flat"
                    Content="&lt;"
                    Command="{Binding NavigateBackCommand}" />

            <TextBlock Grid.Row="0"
                       Grid.Column="1"
                       Classes="H1"
                       Text="{Binding Prescription.Name, StringFormat=Viewing {0}}" />

            <Separator Grid.Row="1"
                       Grid.Column="0"
                       Grid.ColumnSpan="2" />
        </Grid>

        <!-- Lower content -->
        <Grid Grid.Row="1"
              ColumnDefinitions="Auto,*"
              ColumnSpacing="16"
              Margin="16,0,16,0">

            <!-- Left content -->
            <StackPanel Grid.Column="0"
                        Orientation="Vertical"
                        Spacing="16">
                <!-- Image -->
                <Viewbox Height="384"
                         Width="{Binding $self.Height}">
                    <Image asyncImageLoader:ImageLoader.Source="{Binding Prescription.ImageUri}" />
                </Viewbox>

                <Button Classes="Flat"
                        Content="Prescribe to Patient"
                        Command="{Binding PrescribeToPatientCommand}" />
            </StackPanel>

            <!-- Right content -->
            <StackPanel Grid.Column="1"
                        Orientation="Vertical"
                        Spacing="16">
                <TextBlock Classes="H2"
                           Text="{Binding Prescription.Name}" />

                <TextBlock Classes="Body"
                           Text="{Binding Prescription.Description}" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>